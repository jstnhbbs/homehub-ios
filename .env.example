# Local development can use file:local.db. Production should use libsql://…
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Generate each secret independently, for example: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
CALENDAR_ENCRYPTION_KEY=
CRON_SECRET=

# Google Calendar OAuth (optional). Redirect defaults to BETTER_AUTH_URL/api/calendar/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Optional: content value from Google Search Console HTML tag verification
GOOGLE_SITE_VERIFICATION=
BLOB_READ_WRITE_TOKEN=
